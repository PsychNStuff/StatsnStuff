library(reshape2)
library(tidyverse)
library(dplyr)

#to plot correlations between one variable of interest on your x axis and several others on the y axis
#first get just your variables of interest in a dataframe
example_np <- data_np %>% transmute(some_variable_of_interest,
                                                       learning_t, memory_t, ef_t, subid)

np_melt = melt(example_np, id.vars = c("subid", "some_variable_of_interest"))


plot <- ggplot(data=np_melt, aes(x=some_variable_of_interest, y=value, fill = variable, color = variable, group = variable)) +
  scale_colour_manual(values = c("memory_t" = "#784ac7", "learning_t" = "#07aced", "attention_t" = "#f94144",
                                 "ef_t" = "#ffafcc", 'lang_t' = "#90be6d")) + #note that this can have additional variables with colors assigned, so if you only want to plot certain domains, just specify that when you transmute the data
  geom_smooth(method = "lm", size=1, se = T, alpha = 0.08) + #note you can also plot as loess
  theme_bw(base_size = 8) +
  theme(panel.grid.major = element_blank(), axis.text = element_text(color = "black"),panel.grid.minor = element_blank(), axis.line = element_line(colour = "black"), legend.position="bottom")+
  #labs(x="Gamma 1 RMFG Unrelated (residuals)", y="neuropsych (t scores)") +
  theme(aspect.ratio = 1)
plot + scale_fill_manual(values=c("memory_t" = "#784ac7", "learning_t" = "#07aced", "attention_t" = "#f94144",
                                                       "ef_t" = "#ffafcc", 'lang_t' = "#90be6d")) #this should match scale_colour_manual
ggsave("np_plot.tiff", path = "D:/path", units="in", width=5, height=5, dpi=600, compression = 'lzw')

#another option is plotting multiple lines per group with a black trend line for both
plot <- ggplot(example_np, aes(some_variable_of_interest, learning_t fill = as.factor(group))) +
  geom_point(shape = 21, size = 5, show.legend = T, alpha = 0.8, color = "black") +
  theme_minimal() +
  geom_smooth(method = lm, color = "black") +
  scale_fill_manual(values=c("#48cae4", "#c77dff")) +
  theme(legend.position = "none")

plot
ggsave("learning_group_plot.tiff", path = "D:/path", units="in", width=5, height=5, dpi=600, compression = 'lzw')

